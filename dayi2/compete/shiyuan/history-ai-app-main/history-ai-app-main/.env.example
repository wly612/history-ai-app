JWT_SECRET=change-me
PORT=3001

# 钉钉群机器人 Webhook，用于报告页"发送报告到钉钉群"
DINGTALK_WEBHOOK_URL=

# ==================== RAG 知识库配置 ====================
# 是否启用 RAG 检索增强（默认关闭）
RAG_ENABLED=true

# 检索返回的结果数量（默认 5）
RAG_TOP_K=5

# 相似度阈值（0-1，低于此值的结果会被过滤，默认 0.6）
RAG_THRESHOLD=0.6

# 是否启用混合搜索（向量搜索 + 关键词搜索，默认启用）
RAG_USE_HYBRID_SEARCH=true

# 是否启用 RAG 缓存（提升重复查询性能，默认启用）
RAG_USE_CACHE=true

# RAG 缓存过期时间（毫秒，默认 300000 = 5 分钟）
RAG_CACHE_TTL_MS=300000
