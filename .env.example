# 提示：对话大模型依旧使用Gemini API 人格分析模型使用 Deepseek V4 故以下两个API均需填写
# 提示：本地env文件最佳命名为 .env.local 此名称会优先加载 当然.env也可加载 且二者不覆盖只叠加

GEMINI_API_KEY=

AGENT_API_KEY=
AGENT_BASE_URL=https://api.deepseek.com
AGENT_MODEL=deepseek-v4-flash
AGENT_FALLBACK_MODEL=deepseek-v4-pro
AGENT_MAX_STEPS=12
AGENT_THINKING_TYPE=disabled

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=

JWT_SECRET=change-me
PORT=3001

